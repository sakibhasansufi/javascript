2.//Take a number if the number is odd multiply it by 2 and return the result. If the number is even divide it by two and return the result.
const a = 9;
function oddEven(number) {
    console.log(number);
    if (number % 2 === 0) {
        return number/2;
    } else {
        return number*2;
    }
}
const store = oddEven(a);
